DATABASE_URL="file:./acadex.db"
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
PORT=3001

# Google OAuth2
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_REDIRECT_URI="http://localhost:3001/api/auth/google/callback"

# ── AI Scheduling (pick ONE, both are FREE) ──────────────────────────────────
# Option A: Groq cloud — LLaMA 3 70B, free tier (6000 req/day)
#   Sign up at https://console.groq.com → copy API key
GROQ_API_KEY="your-groq-api-key"
GROQ_MODEL="llama-3.3-70b-versatile"

# Option B: Ollama local — completely offline & free
#   Install: https://ollama.com  then run: ollama pull llama3.1
#   (Leave GROQ_API_KEY blank and Ollama is used automatically)
OLLAMA_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.1"

# Frontend URL (for CORS and redirects)
FRONTEND_URL="http://localhost:5173"

# Canvas LMS (optional - users provide their own)
# CANVAS_CLIENT_ID="your-canvas-client-id"
# CANVAS_CLIENT_SECRET="your-canvas-client-secret"
